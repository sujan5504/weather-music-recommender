# Spotify OAuth2 Credentials
# Get these from: https://developer.spotify.com/dashboard/applications
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# OpenWeatherMap API Key
# Get this from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Server Configuration
SERVER_PORT=8081
PROFILE=h2

# Database Configuration (for production use MySQL instead of H2)
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/weathertune
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=your_password_here

# OAuth2 Redirect URI (use localhost:8081 for development, change for production)
OAUTH2_REDIRECT_URI=http://localhost:8081/login/oauth2/code/spotify

